<header class="main-header">
  <div class="container">
    <div class="header-content">
      <!-- Logo/Brand -->
      <div class="header-brand">
        <%= link_to root_path, class: "brand-link" do %>
          <div class="brand-logo">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="logo-icon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            <span class="brand-text">Tattoo Store</span>
          </div>
        <% end %>
      </div>

      <!-- Navigation -->
      <nav class="header-nav">
        <%= link_to "Home", root_path, class: "nav-link #{'active' if current_page?(root_path)}" %>
        <%= link_to "Produtos", web_products_path, class: "nav-link #{'active' if current_page?(web_products_path)}" %>
        <a href="#" class="nav-link">Sobre</a>
        <a href="#" class="nav-link">Contato</a>
      </nav>

      <!-- Actions -->
      <div class="header-actions">
        <!-- Search -->
        <button class="action-btn search-btn" onclick="toggleSearch()">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </button>

        <!-- Cart -->
        <button class="action-btn cart-btn">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4m0 0L7 13m0 0l-2.5 2.5M7 13l2.5 2.5m6-7a2 2 0 100 4 2 2 0 000-4z"></path>
          </svg>
          <span class="cart-count">0</span>
        </button>

        <!-- User Menu -->
        <div class="user-menu">
          <button class="action-btn user-btn" onclick="toggleUserMenu()">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </button>
          <div class="user-dropdown" id="user-dropdown">
            <a href="#" class="dropdown-item">Minha Conta</a>
            <a href="#" class="dropdown-item">Pedidos</a>
            <a href="#" class="dropdown-item">Favoritos</a>
            <div class="dropdown-divider"></div>
            <a href="#" class="dropdown-item">Sair</a>
          </div>
        </div>

        <!-- Mobile Menu Toggle -->
        <button class="mobile-menu-btn" onclick="toggleMobileMenu()">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div class="mobile-menu" id="mobile-menu">
      <div class="mobile-nav">
        <%= link_to "Home", root_path, class: "mobile-nav-link" %>
        <%= link_to "Produtos", web_products_path, class: "mobile-nav-link" %>
        <a href="#" class="mobile-nav-link">Sobre</a>
        <a href="#" class="mobile-nav-link">Contato</a>
      </div>
      <div class="mobile-actions">
        <a href="#" class="mobile-action-link">Minha Conta</a>
        <a href="#" class="mobile-action-link">Carrinho</a>
        <a href="#" class="mobile-action-link">Sair</a>
      </div>
    </div>

    <!-- Search Bar -->
    <div class="search-overlay" id="search-overlay">
      <div class="search-container">
        <div class="search-box">
          <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <input type="text" placeholder="Buscar produtos..." class="search-input" id="global-search">
          <button class="search-close" onclick="toggleSearch()">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
function toggleSearch() {
  const overlay = document.getElementById('search-overlay');
  const input = document.getElementById('global-search');

  if (overlay.classList.contains('active')) {
    overlay.classList.remove('active');
  } else {
    overlay.classList.add('active');
    setTimeout(() => input.focus(), 100);
  }
}

function toggleUserMenu() {
  const dropdown = document.getElementById('user-dropdown');
  dropdown.classList.toggle('active');
}

function toggleMobileMenu() {
  const menu = document.getElementById('mobile-menu');
  menu.classList.toggle('active');

  const btn = document.querySelector('.mobile-menu-btn');
  btn.classList.toggle('active');
}

// Close dropdowns when clicking outside
document.addEventListener('click', function(e) {
  if (!e.target.closest('.user-menu')) {
    document.getElementById('user-dropdown').classList.remove('active');
  }

  if (!e.target.closest('.mobile-menu-btn, .mobile-menu')) {
    document.getElementById('mobile-menu').classList.remove('active');
    document.querySelector('.mobile-menu-btn').classList.remove('active');
  }
});

// Search functionality
document.getElementById('global-search').addEventListener('keypress', function(e) {
  if (e.key === 'Enter') {
    const query = this.value.trim();
    if (query) {
      window.location.href = `/web/products?q[name_i_cont]=${encodeURIComponent(query)}`;
    }
  }
});
</script>
